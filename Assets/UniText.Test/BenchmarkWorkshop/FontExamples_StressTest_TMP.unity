--- !u!114 &1446347299
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1446347297}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<color=#57A64A>// Cat Programmer Simulator</color>\n<color=#569CD6>public
    class</color> <color=#4EC9B0>CatCoder</color>\n{\n    <color=#569CD6>private
    int</color> bugs = <color=#B5CEA8>99</color>;\n    <color=#569CD6>private bool</color>
    sleeping = <color=#569CD6>false</color>;\n    \n    <color=#569CD6>public void</color>
    <color=#DCDCAA>Debug</color>()\n    {\n        <color=#4EC9B0>Console</color>.<color=#DCDCAA>WriteLine</color>(<color=#D69D85>\"Fixing
    bugs...\"</color>);\n        \n        <color=#569CD6>while</color> (bugs > <color=#B5CEA8>0</color>)\n       
    {\n            bugs--;\n            bugs++; <color=#57A64A>// Oops, created new
    bug</color>\n            \n            <color=#569CD6>if</color> (<color=#4EC9B0>Random</color>.<color=#9CDCFE>Shared</color>.<color=#DCDCAA>Next</color>(<color=#B5CEA8>5</color>)
    == <color=#B5CEA8>0</color>)\n            {\n                <color=#DCDCAA>LayOnKeyboard</color>();\n               
    sleeping = <color=#569CD6>true</color>;\n                <color=#569CD6>break</color>;\n           
    }\n        }\n        \n        <color=#4EC9B0>Console</color>.<color=#DCDCAA>WriteLine</color>(<color=#D69D85>$\"Bugs:
    {bugs} | Status: Still debugging\"</color>);\n    }\n    \n    <color=#569CD6>private
    void</color> <color=#DCDCAA>LayOnKeyboard</color>()\n    {\n        <color=#4EC9B0>Console</color>.<color=#DCDCAA>WriteLine</color>(<color=#D69D85>\"asdfghjkl;;;;;;;zzzzz\"</color>);\n   
    }\n}\n\n<color=#57A64A>// Usage:</color>\n<color=#569CD6>var</color> cat = <color=#569CD6>new</color>
    <color=#4EC9B0>CatCoder</color>();\ncat.<color=#DCDCAA>Debug</color>(); <color=#57A64A>//
    Never-ending story</color>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 44c36df162adfe743a2ef826d432004a, type: 2}
